@@ -78,6 +82,79 @@ static u32 s_frames_to_run = 60 * 60;
 static u32 s_frames_remaining = 0;
 static u32 s_frame_dump_interval = 0;
 static std::string s_dump_base_directory;
+static std::string s_gpu_dump_path;
+static u32 s_gpu_dump_start_frame = 0;
+static u32 s_gpu_dump_num_frames = 1;
+
+struct InputScriptEntry
+{
+  u32 start_frame;
+  u32 end_frame;
+  u32 button;
+};
+static std::vector<InputScriptEntry> s_input_script;
+
+// Indices match DigitalController::Button.
+static constexpr const char* s_input_script_button_names[] = {
+  "Select", "L3", "R3", "Start", "Up", "Right", "Down", "Left",
+  "L2",     "R2", "L1", "R1",    "Triangle", "Circle", "Cross", "Square",
+};
+
+static bool LoadInputScript(const char* path)
+{
+  auto fp = FileSystem::OpenManagedCFile(path, "rb");
+  if (!fp)
+  {
+    ERROR_LOG("Failed to open input script '{}'", path);
+    return false;
+  }
+
+  char line[256];
+  u32 line_no = 0;
+  while (std::fgets(line, sizeof(line), fp.get()))
+  {
+    line_no++;
+    char button_name[32];
+    InputScriptEntry entry;
+    if (line[0] == '#' || line[0] == '\n' || line[0] == '\r')
+      continue;
+    if (std::sscanf(line, "%u %u %31s", &entry.start_frame, &entry.end_frame, button_name) != 3)
+    {
+      ERROR_LOG("Malformed input script line {}: expected '<start_frame> <end_frame> <Button>'", line_no);
+      return false;
+    }
+
+    const auto begin = std::begin(s_input_script_button_names);
+    const auto end = std::end(s_input_script_button_names);
+    const auto it = std::find_if(begin, end, [&](const char* name) { return StringUtil::Strcasecmp(name, button_name) == 0; });
+    if (it == end)
+    {
+      ERROR_LOG("Unknown button '{}' in input script line {}", button_name, line_no);
+      return false;
+    }
+
+    entry.button = static_cast<u32>(it - begin);
+    s_input_script.push_back(entry);
+  }
+
+  INFO_LOG("Loaded {} input script entries from '{}'", s_input_script.size(), path);
+  return true;
+}
+
+static void ApplyInputScript(u32 frame)
+{
+  Controller* controller = System::GetController(0);
+  if (!controller)
+    return;
+
+  for (size_t button = 0; button < std::size(s_input_script_button_names); button++)
+  {
+    bool pressed = false;
+    for (const InputScriptEntry& entry : s_input_script)
+      pressed |= (entry.button == button && frame >= entry.start_frame && frame <= entry.end_frame);
+    controller->SetBindState(static_cast<u32>(button), pressed ? 1.0f : 0.0f);
+  }
+}
 
