          }
          PS_CDC_PreSeekHack(cdc, cdc->SeekTarget);
@@ -2524,6 +2565,10 @@ int32_t PS_CDC_Command_Reset(PS_CDC *cdc, const int arg_count, const uint8_t *ar
          cdc->StatusAfterSeek = DS_PAUSED;
